{
    "version": "2",
    "templates": [
        {
            "categories": [
                "Web",
                "Proxy"
            ],
            "description": "Nginx web server preconfigured with Traefik labels for automatic HTTPS routing via Let's Encrypt on the external 'proxy' network.",
            "env": [
                {
                    "default": "1000",
                    "label": "PUID",
                    "name": "PUID"
                },
                {
                    "default": "1000",
                    "label": "PGID",
                    "name": "PGID"
                }
            ],
            "image": "nginx:alpine",
            "logo": "https://raw.githubusercontent.com/docker-library/docs/master/nginx/logo.png",
            "name": "nginx",
            "platform": "linux",
            "ports": [
                "8080:80/tcp",
                "8443:443/tcp"
            ],
            "restart_policy": "unless-stopped",
            "title": "Nginx",
            "type": 1,
            "volumes": [
                {
                    "bind": "./html",
                    "container": "/usr/share/nginx/html:ro"
                }
            ],
            "note": "Requires an external Docker network named <b>proxy</b> and a Traefik instance with a certresolver named <b>le</b>.",
            "maintainer": "https://gitlab.com/infra6221827/dockhand-tpl",
            "id": 1
        }
    ]
}